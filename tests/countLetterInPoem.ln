import io;



main(argc:const(int32),argv:const(ptr(const(str)))):int32
{
    if(argc!=3)
    {
        return -1;
    }
    file:io.stream=io.open(argv[1]);
    searchedLetter:char=argv[2][0];

    count:uint64=0;
    while(!file.eof())
    {
        letter:char=file.putc();
        if(letter==searchedLetter)
        {
            count+=1;
        }
    }

    io.println(str(count));
    return 0;
}
